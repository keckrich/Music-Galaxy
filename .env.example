# ── audiomuse / backend ──────────────────────────────────────────────────────
# Copy these from your audiomuse docker-compose stack.
# Used by: Flask stream proxy (server.py), data fetch (fetch_data.py)
# These are also the vars your production docker-compose already provides.

MEDIASERVER_TYPE=navidrome

# Navidrome
NAVIDROME_URL=http://192.168.x.x:4533
NAVIDROME_USER=your-username
NAVIDROME_PASSWORD=your-password

# Jellyfin (uncomment if using Jellyfin instead)
# JELLYFIN_URL=http://192.168.x.x:8096
# JELLYFIN_USER_ID=your-user-id
# JELLYFIN_TOKEN=your-api-token

# Emby (uncomment if using Emby instead)
# EMBY_URL=http://192.168.x.x:8096
# EMBY_USER_ID=your-user-id
# EMBY_TOKEN=your-api-token

# Lyrion (uncomment if using Lyrion instead)
# LYRION_URL=http://192.168.x.x:9000
